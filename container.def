Bootstrap: docker
From: python:3.10-slim

%files
    pyproject.toml /opt/piper_arm/pyproject.toml
    uv.lock /opt/piper_arm/uv.lock
    README.md /opt/piper_arm/README.md
    piper_arm /opt/piper_arm/piper_arm
    lerobot_policy_advantage /opt/piper_arm/lerobot_policy_advantage

    # To get EGL working
    egl_vendor.d/10_nvidia.json /usr/share/glvnd/egl_vendor.d/10_nvidia.json

%post
    apt-get update && apt-get install -y --no-install-recommends \
        curl ffmpeg libavutil-dev libavcodec-dev libavformat-dev libswscale-dev \
        git linux-libc-dev build-essential cmake \
        libosmesa6-dev libglfw3 \
    && rm -rf /var/lib/apt/lists/*

    # Main install
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="/root/.local/bin:$PATH"
    cd /opt/piper_arm && uv sync --frozen

    # Suppress robotsuite warning
    /opt/piper_arm/.venv/bin/python -m robosuite.scripts.setup_macros

%environment
    export PATH="/root/.local/bin:$PATH"
    export PYTHONDONTWRITEBYTECODE=1
    export PYTHONUNBUFFERED=1
    export MUJOCO_GL=egl
    export PYOPENGL_PLATFORM=egl
    export TOKENIZERS_PARALLELISM=false

    # Cache directories
    export CACHE_DIR=${CACHE_DIR:-/data/engs-robotics-ml/kebl6123/piper_arm/.cache}
    export UV_CACHE_DIR=$CACHE_DIR/uv
    export HF_HOME=$CACHE_DIR/huggingface
    export LIBERO_CONFIG_PATH=$CACHE_DIR/libero
    export WANDB_CACHE_DIR=$CACHE_DIR/wandb
    export TORCHINDUCTOR_CACHE_DIR=$CACHE_DIR/torchinductor

%runscript
    . /opt/piper_arm/.venv/bin/activate
    exec "$@"
